# Backend port (frontend runs on 3001 — see frontend/package.json)
PORT=3003
FRONTEND_URL=http://localhost:3001

NODE_ENV=development

# Local Docker Postgres (or use DATABASE_URL for Neon)
DB_HOST=localhost
DB_PORT=5433
DB_USERNAME=tarot
DB_PASSWORD=tarot
DB_DATABASE=tarot
DB_SSL=false

# Neon / managed Postgres — if set, DB_* above are ignored
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

DEEPSEEK_API_KEY=

NEXT_PUBLIC_CONTACT_EMAIL=
